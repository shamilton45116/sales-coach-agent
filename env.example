# Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Gong MCP
# Token: get from your Gong admin or Gong developer portal
# URL: confirm at https://developers.gong.io/docs/mcp (defaults to https://mcp.gong.io/mcp)
GONG_MCP_TOKEN=your_gong_mcp_token_here
GONG_MCP_URL=https://mcp.gong.io/mcp

# Optional: comma-separated rep emails to limit scoring to your sales team
# Leave blank to include all internal Gong users
GONG_TEAM_EMAILS=alice@company.com,bob@company.com

# Slack Incoming Webhook URL
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
